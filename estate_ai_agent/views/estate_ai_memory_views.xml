<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="estate_ai_memory_view_list" model="ir.ui.view">
        <field name="name">estate.ai.memory.list</field>
        <field name="model">estate.ai.memory</field>
        <field name="arch" type="xml">
            <list string="Memorias del Agente" decoration-muted="not is_active">
                <field name="create_date" string="Guardada"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="memory_type" widget="badge"
                    decoration-info="memory_type == 'preference'"
                    decoration-success="memory_type == 'fact'"
                    decoration-warning="memory_type == 'alert'"
                    decoration-primary="memory_type == 'client'"/>
                <field name="title"/>
                <field name="content"/>
                <field name="tags"/>
                <field name="expires_at"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="estate_ai_memory_view_form" model="ir.ui.view">
        <field name="name">estate.ai.memory.form</field>
        <field name="model">estate.ai.memory</field>
        <field name="arch" type="xml">
            <form string="Memoria del Agente IA">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="title" placeholder="Título de la memoria..."/></h1>
                    </div>
                    <group>
                        <group string="Clasificación">
                            <field name="user_id"/>
                            <field name="memory_type"/>
                            <field name="tags" placeholder="clave1, clave2, ..."/>
                            <field name="expires_at"/>
                            <field name="is_active" readonly="1"/>
                        </group>
                        <group string="Entidades Relacionadas (opcional)">
                            <field name="lead_id"/>
                            <field name="property_id"/>
                            <field name="partner_id"/>
                        </group>
                    </group>
                    <group string="Contenido">
                        <field name="content" nolabel="1" placeholder="Información que el agente debe recordar..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="estate_ai_memory_view_search" model="ir.ui.view">
        <field name="name">estate.ai.memory.search</field>
        <field name="model">estate.ai.memory</field>
        <field name="arch" type="xml">
            <search string="Buscar Memorias">
                <field name="title"/>
                <field name="content"/>
                <field name="tags"/>
                <field name="user_id"/>
                <filter string="Activas" name="filter_active" domain="[('is_active','=',True)]"/>
                <filter string="Expiradas" name="filter_expired" domain="[('is_active','=',False)]"/>
                <separator/>
                <filter string="Preferencias" name="filter_preference" domain="[('memory_type','=','preference')]"/>
                <filter string="Alertas" name="filter_alert" domain="[('memory_type','=','alert')]"/>
                <filter string="Clientes" name="filter_client" domain="[('memory_type','=','client')]"/>
                <group>
                    <filter string="Usuario" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Tipo" name="group_type" context="{'group_by': 'memory_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="estate_ai_memory_action" model="ir.actions.act_window">
        <field name="name">Memorias del Agente</field>
        <field name="res_model">estate.ai.memory</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="estate_ai_memory_view_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay memorias guardadas todavía
            </p>
            <p>El agente IA guardará aquí información importante de tus conversaciones.</p>
        </field>
    </record>
</odoo>
