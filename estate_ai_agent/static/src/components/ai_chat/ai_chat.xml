<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="estate_ai_agent.AIChat">
        <div class="estate-ai-chat-container">
            <!-- Header -->
            <div class="estate-ai-header">
                <div class="estate-ai-header-title">
                    <svg class="estate-ai-header-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2a1 1 0 011 1v1.07A7.002 7.002 0 0119 11v1h1a2 2 0 012 2v2a2 2 0 01-2 2h-1v1a3 3 0 01-3 3H8a3 3 0 01-3-3v-1H4a2 2 0 01-2-2v-2a2 2 0 012-2h1v-1a7.002 7.002 0 016-6.93V3a1 1 0 011-1zm0 4a5 5 0 00-5 5v8a1 1 0 001 1h8a1 1 0 001-1v-8a5 5 0 00-5-5zm-2.5 6a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm5 0a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/>
                    </svg>
                    InmoBot
                    <span t-if="state.loading" class="estate-ai-status-dot ms-2">
                        <span class="estate-ai-spinner"/>
                        <small class="text-muted ms-1">Procesando...</small>
                    </span>
                </div>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-info" t-on-click="toggleOcrMode"
                            t-att-class="state.ocrMode ? 'btn-info text-white' : 'btn-outline-info'">
                        <i class="fa fa-file-image-o"/> OCR
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="clearChat">
                        <i class="fa fa-trash"/>
                    </button>
                </div>
            </div>

            <!-- OCR Banner -->
            <t t-if="state.ocrMode">
                <div class="alert alert-info m-2 p-2 d-flex align-items-center gap-2">
                    <i class="fa fa-camera fa-lg"/>
                    <span>Modo OCR activo — sube una imagen o PDF para extraer datos automáticamente.</span>
                    <button class="btn btn-sm btn-info ms-auto" t-on-click="triggerFileUpload">
                        <i class="fa fa-upload"/> Subir Archivo
                    </button>
                </div>
                <input t-ref="fileInput" type="file" class="d-none"
                       accept="image/*,.pdf"
                       t-on-change="onFileSelected"/>
            </t>

            <!-- Chat Body -->
            <div class="estate-ai-body" t-ref="chatBody">
                <!-- Welcome message -->
                <t t-if="!state.messages.length">
                    <div class="estate-ai-welcome">
                        <div class="estate-ai-welcome-avatar">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 2a1 1 0 011 1v1.07A7.002 7.002 0 0119 11v1h1a2 2 0 012 2v2a2 2 0 01-2 2h-1v1a3 3 0 01-3 3H8a3 3 0 01-3-3v-1H4a2 2 0 01-2-2v-2a2 2 0 012-2h1v-1a7.002 7.002 0 016-6.93V3a1 1 0 011-1zm0 4a5 5 0 00-5 5v8a1 1 0 001 1h8a1 1 0 001-1v-8a5 5 0 00-5-5zm-2.5 6a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm5 0a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/>
                            </svg>
                        </div>
                        <h3>¡Hola! Soy InmoBot</h3>
                        <p>Tu asistente inmobiliario con IA. Consulta, crea y gestiona propiedades, leads, contratos y más.</p>
                    </div>
                </t>

                <!-- Messages -->
                <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                    <div t-attf-class="estate-ai-message estate-ai-message-{{ msg.type }}">
                        <div class="estate-ai-message-avatar">
                            <t t-if="msg.type === 'user'">
                                <svg class="estate-ai-avatar-svg estate-ai-avatar-user" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                </svg>
                            </t>
                            <t t-else="">
                                <svg class="estate-ai-avatar-svg estate-ai-avatar-bot" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 2a1 1 0 011 1v1.07A7.002 7.002 0 0119 11v1h1a2 2 0 012 2v2a2 2 0 01-2 2h-1v1a3 3 0 01-3 3H8a3 3 0 01-3-3v-1H4a2 2 0 01-2-2v-2a2 2 0 012-2h1v-1a7.002 7.002 0 016-6.93V3a1 1 0 011-1zm0 4a5 5 0 00-5 5v8a1 1 0 001 1h8a1 1 0 001-1v-8a5 5 0 00-5-5zm-2.5 6a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm5 0a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/>
                                </svg>
                            </t>
                        </div>
                        <div class="estate-ai-message-content">
                            <!-- Confirmation warning banner -->
                            <t t-if="msg.type === 'bot' and isConfirmationNeeded(msg.text)">
                                <div class="alert alert-warning p-2 mb-2 d-flex align-items-center gap-2">
                                    <svg viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                                        <path fill="#856404" d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
                                    </svg>
                                    <strong>Acción destructiva detectada</strong>
                                </div>
                            </t>

                            <t t-if="msg.type === 'user'">
                                <t t-esc="msg.text"/>
                            </t>
                            <t t-else="">
                                <t t-out="formatResponse(msg.text)"/>
                            </t>

                            <!-- Copy button for bot messages -->
                            <t t-if="msg.type === 'bot' and msg.copyable and !msg.streaming">
                                <div class="mt-1">
                                    <button class="btn btn-xs btn-outline-secondary estate-ai-copy-btn"
                                            t-on-click="() => this.copyMessage(msg)">
                                        <t t-if="msg.copied">
                                            <i class="fa fa-check text-success"/> Copiado
                                        </t>
                                        <t t-else="">
                                            <i class="fa fa-copy"/> Copiar
                                        </t>
                                    </button>
                                </div>
                            </t>

                            <div class="estate-ai-message-time">
                                <small><t t-esc="msg.date"/></small>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Suggestions (shown when no messages) -->
            <t t-if="state.suggestions.length and !state.messages.length">
                <div class="estate-ai-suggestions">
                    <t t-foreach="state.suggestions" t-as="suggestion" t-key="suggestion_index">
                        <button class="btn btn-outline-primary btn-sm estate-ai-suggestion-btn"
                                t-on-click="() => this.useSuggestion(suggestion)">
                            <t t-esc="suggestion"/>
                        </button>
                    </t>
                </div>
            </t>

            <!-- Contextual chips (shown after responses) -->
            <t t-if="state.showChips and state.messages.length">
                <div class="estate-ai-suggestions estate-ai-chips">
                    <small class="text-muted d-block mb-1">Sugerencias rápidas:</small>
                    <t t-foreach="['¿Cuántas propiedades disponibles?', 'Leads más calientes', 'Pagos vencidos', 'Reporte del mes', 'Recordar preferencia']" t-as="chip" t-key="chip_index">
                        <button class="btn btn-outline-secondary btn-xs estate-ai-suggestion-btn"
                                t-on-click="() => this.useChip(chip)">
                            <t t-esc="chip"/>
                        </button>
                    </t>
                </div>
            </t>

            <!-- Input -->
            <div class="estate-ai-input">
                <textarea
                    class="form-control"
                    placeholder="Escribe tu consulta o pídeme que haga algo..."
                    t-model="state.inputText"
                    t-on-keydown="onKeydown"
                    rows="2"
                />
                <button class="btn btn-primary estate-ai-send-btn"
                        t-on-click="() => this.sendMessage()"
                        t-att-disabled="state.loading || !state.inputText.trim()">
                    <t t-if="state.loading">
                        <span class="estate-ai-spinner"/>
                    </t>
                    <t t-else="">
                        <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
                            <path fill="white" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                        </svg>
                    </t>
                </button>
            </div>
        </div>
    </t>
</templates>
