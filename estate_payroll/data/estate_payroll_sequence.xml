<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_estate_payroll_line" model="ir.sequence">
        <field name="name">Nómina Inmobiliaria</field>
        <field name="code">estate.payroll.line</field>
        <field name="prefix">NOM/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>
    <record id="default_iess_personal_pct" model="ir.config_parameter">
        <field name="key">estate_payroll.iess_personal_pct</field>
        <field name="value">9.45</field>
    </record>
</odoo>
