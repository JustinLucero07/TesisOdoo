    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, wp_post_id, title\nFROM estate_property\nWHERE active = true\n  AND (\n    -- Buscar por property_id (id de Odoo) o por wp_post_id pasado como property_id\n    ({{ $json.property_id }} > 0 AND (\n      id = {{ $json.property_id }}\n      OR wp_post_id = {{ $json.property_id }}\n    ))\n    OR\n    -- Buscar por wp_post_id directo si se paso por separado\n    ({{ $json.property_id }} = 0 AND {{ $json.wp_post_id }} > 0 AND\n      wp_post_id = {{ $json.wp_post_id }}\n    )\n    OR\n    -- Fallback: buscar por texto cuando no hay ningun id\n    ({{ $json.property_id }} = 0 AND {{ $json.wp_post_id }} = 0 AND\n      '{{ $json.busqueda }}' != '' AND (\n        title  ILIKE '%' || '{{ $json.busqueda }}' || '%'\n        OR city   ILIKE '%' || '{{ $json.busqueda }}' || '%'\n        OR street ILIKE '%' || '{{ $json.busqueda }}' || '%'\n        OR COALESCE(sector_keywords,'') ILIKE '%' || '{{ $json.busqueda }}' || '%'\n      )\n    )\n  )\nORDER BY (wp_post_id IS NOT NULL AND wp_post_id > 0) DESC, id DESC\nLIMIT 1;\n",
        "options": {}
      },
      "id": "ef03-dbquery",
      "name": "Obtener wp_post_id de DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        680,
        0
      ],
      "credentials": {
        "postgres": {
          "id": "6mYPUyfDHs6x1dvZ",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Merge DB result with trigger params\nconst triggerData = $('Preparar Params').first().json;\nconst dbRow = $input.first().json;\n\n// wp_post_id: prefer the one from trigger, fallback to DB\nconst wp_post_id = (triggerData.wp_post_id && triggerData.wp_post_id > 0)\n  ? triggerData.wp_post_id\n  : (dbRow.wp_post_id || 0);\n\nif (!wp_post_id || wp_post_id === 0) {\n  return [{ json: {\n    error: 'Esta propiedad no está publicada en el sitio web todavía. No hay fotos disponibles.',\n    enviadas: 0,\n    phone: triggerData.phone,\n    phoneNumberId: triggerData.phoneNumberId\n  }}];\n}\n\nreturn [{ json: {\n  wp_post_id,\n  phone:         triggerData.phone,\n  phoneNumberId: triggerData.phoneNumberId,\n  property_id:   triggerData.property_id\n}}];"
      },
      "id": "ef04-merge",
      "name": "Resolver wp_post_id",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
