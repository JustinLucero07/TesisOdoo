      "id": "ef05-ifcheck",
      "name": "¿Tiene WordPress?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1120,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://inmobi.com.ec/wp-json/wp/v2/media?parent={{ $json.wp_post_id }}&per_page=5&_fields=source_url,alt_text&orderby=id&order=asc",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "ef06-wpapi",
      "name": "Buscar Fotos en WordPress",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse WP response and create one item per image (max 5)\nconst allItems = $input.all();\nconst phone         = $('Resolver wp_post_id').first().json.phone;\nconst phoneNumberId = $('Resolver wp_post_id').first().json.phoneNumberId;\n\n// WP API returns an array directly\nlet images = [];\nfor (const item of allItems) {\n  const body = item.json;\n  if (Array.isArray(body)) {\n    images = images.concat(body);\n  } else if (body && body.source_url) {\n    images.push(body);\n  }\n}\nimages = images.slice(0, 5);\n\nif (images.length === 0) {\n  return [{ json: {\n    error: 'No encontré fotos de esta propiedad en el sitio web.',\n    enviadas: 0\n  }}];\n}\n\nconst total = images.length;\nreturn images.map((img, idx) => ({\n  json: {\n    source_url:    img.source_url,\n    caption:       `Foto ${idx + 1} de ${total}`,\n    phone,\n    phoneNumberId,\n    idx,\n    total\n  }\n}));"
      },
      "id": "ef07-parselist",
      "name": "Preparar Lista Fotos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        -80
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v25.0/{{ $json.phoneNumberId }}/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "whatsAppApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.phone }}\",\n  \"type\": \"image\",\n  \"image\": {\n    \"link\": \"{{ $json.source_url }}\",\n    \"caption\": \"{{ $json.caption }}\"\n  }\n}",
        "options": {
          "timeout": 15000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "ef08-sendimg",
      "name": "Enviar Foto WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1780,
        -80
      ],
      "credentials": {
        "whatsAppApi": {
          "id": "DOEaWrSOaR0CWKbo",
          "name": "WhatsApp account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Aggregate results from all image sends\nconst items = $input.all();\nlet enviadas = 0;\nlet errores  = 0;\nfor (const item of items) {\n  const body = item.json;\n  // Meta returns { messages: [{id}] } on success\n  if (body && body.messages && body.messages.length > 0) {\n    enviadas++;\n  } else {\n    errores++;\n  }\n}\nreturn [{ json: {\n  enviadas,\n  errores,\n  response: enviadas > 0\n    ? `${enviadas} foto(s) enviada(s) correctamente.`\n    : 'No se pudieron enviar las fotos. Intenta más tarde.'\n}}];"
      },
