    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT phone, nombre, intent, state, context, history, last_activity FROM wa_sessions WHERE phone = '{{ $json.numero }}' LIMIT 1;",
        "options": {}
      },
      "id": "rt-read-db",
      "name": "Leer Sesion DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [680, 0],
      "credentials": { "postgres": { "id": "6mYPUyfDHs6x1dvZ", "name": "Postgres account" } }
    },
    {
      "parameters": {
        "jsCode": "// Merge DB session with current message data\nconst msgData = $('Contexto de Fechas').first().json;\nconst dbRows  = $input.all().map(i => i.json);\nconst session = dbRows.find(r => r.phone) || {};\n\nconst currentIntent = (session.intent || 'UNKNOWN').toUpperCase();\nconst nombre        = session.nombre || msgData.nombre || '';\nconst history       = session.history || [];\nconst context       = session.context || {};\nconst state         = session.state   || 'greeting';\n\n// If we already know the intent, reuse it\nif (currentIntent !== 'UNKNOWN' && state !== 'done') {\n  return [{ json: {\n    ...msgData,\n    intent: currentIntent,\n    nombre, history: JSON.stringify(history),\n    context_json: JSON.stringify(context),\n    isNew: false\n  }}];\n}\n\n// New client — keyword classification (instant, no LLM cost)\nconst msg = (msgData.mensaje || '').toLowerCase();\nconst venderKw   = ['vender','vendo','venta de','tengo una','quiero vender','propietario','mi propiedad'];\nconst avaluoKw   = ['avalúo','avaluo','cuánto vale','valoración','tasación','valor de mi'];\nlet intent = 'COMPRADOR';\nfor (const kw of avaluoKw) { if (msg.includes(kw)) { intent = 'AVALUO'; break; } }\nfor (const kw of venderKw)  { if (msg.includes(kw)) { intent = 'VENDEDOR'; break; } }\n\nreturn [{ json: {\n  ...msgData,\n  intent,\n  nombre,\n  history: JSON.stringify([]),\n  context_json: JSON.stringify({}),\n  isNew: true\n}}];"
      },
      "id": "rt-classify",
      "name": "Clasificar Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 0]
