    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst entry = body?.entry?.[0];\nconst change = entry?.changes?.[0];\nconst msg = change?.value?.messages?.[0];\nconst contact = change?.value?.contacts?.[0];\nconst metadata = change?.value?.metadata;\n\nif (!msg) return [{ json: { skip: true } }];\n\nreturn [{ json: {\n  mensaje:         msg.text?.body || '',\n  numero:          msg.from,\n  nombre:          contact?.profile?.name || '',\n  tipo:            msg.type,\n  audioId:         msg.audio?.id || '',\n  phoneNumberId:   metadata?.phone_number_id || '1117287444793731'\n}}];"
      },
      "id": "rt-extract",
      "name": "Extraer Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [20, 0]
    },
    {
      "parameters": {
        "jsCode": "// Inject date context (UTC-5 Ecuador)\nconst d = $input.first().json;\nif (d.skip) return [{ json: d }];\n\nconst now = new Date(Date.now() - 5 * 3600000);\nconst pad = n => String(n).padStart(2,'0');\nconst fmt = dt => `${dt.getUTCFullYear()}-${pad(dt.getUTCMonth()+1)}-${pad(dt.getUTCDate())}`;\n\nconst hoy = new Date(now);\nconst manana = new Date(now); manana.setUTCDate(manana.getUTCDate()+1);\nconst dow = now.getUTCDay(); // 0=Sun\nconst lunes = new Date(now); lunes.setUTCDate(now.getUTCDate() + (dow===0?1:8-dow)%7 || 7);\n// This week days\nconst diasSemana = ['domingo','lunes','martes','miercoles','jueves','viernes','sabado'];\nconst semana = {};\nfor (let i=0;i<7;i++) { const d2=new Date(now); d2.setUTCDate(now.getUTCDate()-dow+i); semana[diasSemana[i]]=fmt(d2); }\n// Next week\nconst semanaProx = {};\nfor (let i=0;i<7;i++) { const d2=new Date(now); d2.setUTCDate(now.getUTCDate()-dow+i+7); semanaProx[diasSemana[i]+'_proxima']=fmt(d2); }\n\nconst fechaCtx = `\\n🗓️ CONTEXTO DE FECHAS (solo para ti):\\nHoy: ${fmt(hoy)} (${diasSemana[dow]})\\nMañana: ${fmt(manana)}\\nEsta semana: ${JSON.stringify(semana)}\\nPróxima semana: ${JSON.stringify(semanaProx)}\\n`;\n\nreturn [{ json: { ...d, fecha_contexto: fechaCtx } }];"
      },
