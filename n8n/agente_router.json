    {
      "parameters": {
        "jsCode": "// Merge response with original session context, then UPSERT to wa_sessions\nconst resp      = $input.first().json.response || $input.first().json.output || '';\nconst classify  = $('Clasificar Intent').first().json;\nconst numero    = classify.numero;\nconst intent    = classify.intent;\nconst nombre    = classify.nombre;\nconst mensaje   = classify.mensaje;\n\nconst oldHistory = JSON.parse(classify.history || '[]');\nconst newHistory = [\n  ...oldHistory,\n  { role: 'human', content: mensaje, ts: new Date().toISOString() },\n  { role: 'ai',    content: resp,    ts: new Date().toISOString() }\n].slice(-20); // keep last 20 messages\n\nreturn [{ json: {\n  phone:   numero,\n  nombre:  nombre,\n  intent:  intent,\n  history: JSON.stringify(newHistory),\n  response: resp\n}}];"
      },
      "id": "rt-prep-save",
      "name": "Preparar Guardar Sesion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 0]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO wa_sessions (phone, nombre, intent, state, history, last_activity)\nVALUES (\n  '{{ $json.phone }}',\n  '{{ $json.nombre.replace(/'/g, \"''\") }}',\n  '{{ $json.intent }}',\n  'active',\n  '{{ $json.history }}'::jsonb,\n  NOW()\n)\nON CONFLICT (phone) DO UPDATE SET\n  nombre        = EXCLUDED.nombre,\n  intent        = EXCLUDED.intent,\n  state         = 'active',\n  history       = EXCLUDED.history,\n  last_activity = NOW();",
        "options": {}
      },
