    {
      "parameters": {
        "jsCode": "// Merge transcribed audio into message format\nconst transcription = $input.first().json.text || '';\nconst orig = $('Contexto de Fechas').first().json;\nreturn [{ json: { ...orig, mensaje: transcription, tipo: 'text' } }];"
      },
