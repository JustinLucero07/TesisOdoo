# ── Copia este archivo a .env y rellena los valores ──────────────────────────
# cp .env.example .env && nano .env

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_CLAVE_SEGURA

# Dominios
ODOO_HOST=erp.tudominio.com
N8N_HOST=n8n.tudominio.com

# n8n — clave de 32+ chars aleatoria
N8N_ENCRYPTION_KEY=GENERA_CON__openssl_rand_-hex_32

# Email (opcional para notificaciones n8n)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu_app_password

# Odoo admin master password
ODOO_ADMIN_PASSWD=CAMBIA_ESTO_TAMBIEN
