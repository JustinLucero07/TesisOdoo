<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_report_wizard_view_form" model="ir.ui.view">
        <field name="name">estate.report.wizard.form</field>
        <field name="model">estate.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar Datos a Excel">
                <group>
                    <group string="Tipo de Reporte">
                        <field name="report_type" widget="radio"/>
                        <field name="export_format" invisible="1"/>
                    </group>
                    <group string="Período (opcional)">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Exportar Excel" type="object" class="oe_highlight" icon="fa-download"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="estate_report_wizard_action" model="ir.actions.act_window">
        <field name="name">Exportar Datos a Excel</field>
        <field name="res_model">estate.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
