<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_estate_wp" model="ir.ui.view">
        <field name="name">res.users.form.estate.wp</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Página Web (WordPress)" name="wp_houzez">
                    <group>
                        <field name="wp_agent_id"/>
                    </group>
                    <p class="text-muted"><i class="fa fa-info-circle"/> Vincula tu usuario de Odoo con tu Perfil Púbico en Houzez para que los clientes te puedan contactar a ti cuando publiques una propiedad.</p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
