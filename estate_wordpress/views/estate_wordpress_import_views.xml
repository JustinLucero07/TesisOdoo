<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- Wizard: Importar Propiedades desde WordPress                  -->
        <!-- ============================================================ -->
        <record id="estate_wp_import_wizard_view_form" model="ir.ui.view">
            <field name="name">estate.wordpress.import.wizard.form</field>
            <field name="model">estate.wordpress.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Importar Propiedades desde WordPress">

                    <!-- ======= PASO 1: CONFIGURACIÓN ======= -->
                    <group invisible="import_state != 'draft'">
                        <group string="Opciones de Importación">
                            <field name="max_properties"/>
                            <field name="import_images"
                                   help="Activa esto para descargar imagen principal y galería. Tarda más tiempo."/>
                            <field name="update_existing"
                                   help="Si está activo, las propiedades ya existentes (por Post ID de WP) serán actualizadas."/>
                        </group>
                        <group string="Información">
                            <div class="text-muted">
                                <p>
                                    Se conectará a tu WordPress configurado en
                                    <b>Ajustes → Integración WordPress</b>
                                    y descargará las propiedades via REST API.
                                </p>
                                <p>
                                    En el siguiente paso podrás <b>seleccionar</b>
                                    cuáles propiedades importar.
                                </p>
                                <p class="text-warning">
                                    Si activas <b>Importar Imágenes</b>, el proceso puede tardar
                                    varios minutos dependiendo de la cantidad de fotos.
                                </p>
                            </div>
                        </group>
                    </group>

                    <!-- ======= PASO 2: SELECCIÓN ======= -->
                    <group invisible="import_state != 'preview'">
                        <div class="alert alert-info mb-2 py-2 px-3" role="alert"
                             style="border-radius:8px; font-size:0.88em;">
                            <i class="fa fa-info-circle" title="Info"/>
                            Se encontraron <strong><field name="preview_total" readonly="1" class="d-inline"/></strong>
                            propiedades en WordPress. Selecciona las que deseas importar.
                            Las que ya existen en Odoo aparecen desmarcadas.
                        </div>
                        <div class="mb-2">
                            <button name="action_select_all" string="Todas"
                                    type="object" class="btn-sm btn-outline-primary me-1"/>
                            <button name="action_select_none" string="Ninguna"
                                    type="object" class="btn-sm btn-outline-secondary me-1"/>
                            <button name="action_select_new_only" string="Solo nuevas"
                                    type="object" class="btn-sm btn-outline-success"/>
                        </div>
                    </group>
                    <field name="preview_line_ids" invisible="import_state != 'preview'">
                        <list editable="bottom"
                              decoration-muted="already_exists == True"
                              decoration-success="selected == True and already_exists == False">
                            <field name="selected"/>
                            <field name="wp_post_id" string="ID" readonly="1"/>
                            <field name="title" readonly="1"/>
                            <field name="price" readonly="1" widget="monetary"/>
                            <field name="area" readonly="1"/>
                            <field name="bedrooms" readonly="1"/>
                            <field name="city" readonly="1"/>
                            <field name="already_exists" string="¿Existe?" readonly="1" widget="boolean"/>
                        </list>
                    </field>

                    <!-- ======= PASO 3: RESULTADOS ======= -->
                    <group invisible="import_state != 'done'">
                        <group string="Resultado de la Importación">
                            <field name="imported_count" string="Propiedades nuevas importadas"/>
                            <field name="updated_count"  string="Propiedades actualizadas"/>
                            <field name="skipped_count"  string="Propiedades omitidas (ya existían)"/>
                        </group>
                        <group string=" " invisible="not error_log">
                            <field name="error_log" string="Errores encontrados" widget="text"
                                   readonly="1" nolabel="1"/>
                        </group>
                        <group string=" " invisible="error_log">
                            <div class="text-success">
                                <b>Importación completada sin errores.</b>
                            </div>
                        </group>
                    </group>

                    <!-- Campo oculto de estado -->
                    <field name="import_state" invisible="1"/>

                    <footer>
                        <!-- Paso 1: Buscar en WP -->
                        <button name="action_preview"
                                string="Buscar Propiedades en WordPress"
                                type="object"
                                icon="fa-search"
                                class="btn-primary"
                                invisible="import_state != 'draft'"/>
                        <button string="Cancelar"
                                class="btn-secondary"
                                special="cancel"
                                invisible="import_state != 'draft'"/>

                        <!-- Paso 2: Importar seleccionadas -->
                        <button name="action_import"
                                string="Importar Seleccionadas"
                                type="object"
                                icon="fa-download"
                                class="btn-primary"
                                invisible="import_state != 'preview'"/>
                        <button string="Cancelar"
                                class="btn-secondary"
                                special="cancel"
                                invisible="import_state != 'preview'"/>

                        <!-- Paso 3: Ver resultados -->
                        <button name="action_view_imported_properties"
                                string="Ver Propiedades Importadas"
                                type="object"
                                class="btn-primary"
                                invisible="import_state != 'done'"/>
                        <button string="Cerrar"
                                class="btn-secondary"
                                special="cancel"
                                invisible="import_state != 'done'"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para abrir el wizard -->
        <record id="action_estate_wp_import_wizard" model="ir.actions.act_window">
            <field name="name">Importar desde WordPress</field>
            <field name="res_model">estate.wordpress.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
