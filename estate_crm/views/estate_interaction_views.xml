<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_interaction_view_tree" model="ir.ui.view">
        <field name="name">estate.client.interaction.tree</field>
        <field name="model">estate.client.interaction</field>
        <field name="arch" type="xml">
            <list string="Interacciones">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="interaction_type" widget="badge"/>
                <field name="summary"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="property_id"/>
            </list>
        </field>
    </record>

    <record id="estate_interaction_view_form" model="ir.ui.view">
        <field name="name">estate.client.interaction.form</field>
        <field name="model">estate.client.interaction</field>
        <field name="arch" type="xml">
            <form string="Interacción">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="date"/>
                        <field name="interaction_type" widget="radio"/>
                    </group>
                    <group>
                        <field name="user_id" widget="many2one_avatar_user"/>
                        <field name="property_id"/>
                    </group>
                </group>
                <group string="Resumen">
                    <field name="summary" nolabel="1"/>
                </group>
            </form>
        </field>
    </record>

    <record id="estate_interaction_action" model="ir.actions.act_window">
        <field name="name">Interacciones</field>
        <field name="res_model">estate.client.interaction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
