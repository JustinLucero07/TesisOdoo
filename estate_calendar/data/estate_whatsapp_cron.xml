<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: WhatsApp Reminders every 30 minutes -->
        <record id="ir_cron_whatsapp_reminders" model="ir.cron">
            <field name="name">WhatsApp: Recordatorios de Citas</field>
            <field name="model_id" ref="model_calendar_event"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_whatsapp_reminders()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
