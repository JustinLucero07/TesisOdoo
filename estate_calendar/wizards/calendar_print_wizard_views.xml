<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="calendar_print_wizard_form" model="ir.ui.view">
        <field name="name">calendar.print.wizard.form</field>
        <field name="model">calendar.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Imprimir Agenda Semanal">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="user_id" placeholder="Todos los asesores"/>
                        <field name="only_visits"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print" string="Imprimir PDF" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_calendar_print_wizard" model="ir.actions.act_window">
        <field name="name">Imprimir Agenda Semanal</field>
        <field name="res_model">calendar.print.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
