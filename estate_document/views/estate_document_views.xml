<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_document_view_tree" model="ir.ui.view">
        <field name="name">estate.document.tree</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <list string="Documentos">
                <field name="name"/>
                <field name="document_type" widget="badge"/>
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="lead_id"/>
                <field name="date"/>
                <field name="filename"/>
            </list>
        </field>
    </record>

    <record id="estate_document_view_form" model="ir.ui.view">
        <field name="name">estate.document.form</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <form string="Documento">
                <sheet>
                    <group>
                        <group string="Información del Documento">
                            <field name="name"/>
                            <field name="document_type" widget="radio"/>
                            <field name="date"/>
                        </group>
                        <group string="Archivo">
                            <field name="file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </group>
                    </group>
                    <group string="Vinculación">
                        <group>
                            <field name="property_id"/>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                        </group>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_document_view_search" model="ir.ui.view">
        <field name="name">estate.document.search</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <search string="Buscar Documento">
                <field name="name"/>
                <field name="property_id"/>
                <field name="partner_id"/>
                <filter name="filter_contract" string="Contratos" domain="[('document_type', '=', 'contract')]"/>
                <filter name="filter_legal" string="Legales" domain="[('document_type', '=', 'legal')]"/>
                <filter name="filter_deed" string="Escrituras" domain="[('document_type', '=', 'deed')]"/>
                <group>
                    <filter name="group_type" string="Tipo" context="{'group_by': 'document_type'}"/>
                    <filter name="group_property" string="Propiedad" context="{'group_by': 'property_id'}"/>
                    <filter name="group_partner" string="Cliente" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="estate_document_action" model="ir.actions.act_window">
        <field name="name">Documentos</field>
        <field name="res_model">estate.document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Subir un nuevo documento
            </p>
        </field>
    </record>
    <record id="crm_lead_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.docs</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Documentación Confidencial" name="estate_docs">
                    <field name="document_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="document_type"/>
                            <field name="date"/>
                            <field name="file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Smart Button en Propiedad -->
    <record id="estate_property_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">estate.property.form.inherit.docs</field>
        <field name="model">estate.property</field>
        <field name="inherit_id" ref="estate_management.estate_property_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object" class="oe_stat_button" icon="fa-file-text-o">
                    <field name="document_count" widget="statinfo" string="Documentos"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Smart Button en Cliente -->
    <record id="res_partner_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.docs</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object" class="oe_stat_button" icon="fa-file-text-o">
                    <field name="document_count" widget="statinfo" string="Documentos"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
