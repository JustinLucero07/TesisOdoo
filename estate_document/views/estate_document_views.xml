<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         VISTAS DEL TIPO DE DOCUMENTO (catálogo configurable)
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_type_view_list" model="ir.ui.view">
        <field name="name">estate.document.type.list</field>
        <field name="model">estate.document.type</field>
        <field name="arch" type="xml">
            <list string="Tipos de Documento" default_order="category, sequence">
                <field name="sequence" widget="handle"/>
                <field name="category"/>
                <field name="name"/>
                <field name="code"/>
                <field name="icon"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="estate_document_type_view_form" model="ir.ui.view">
        <field name="name">estate.document.type.form</field>
        <field name="model">estate.document.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Documento">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="icon"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_estate_document_type" model="ir.actions.act_window">
        <field name="name">Tipos de Documento</field>
        <field name="res_model">estate.document.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         WIZARD DE RECHAZO
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_reject_wizard_view_form" model="ir.ui.view">
        <field name="name">estate.document.reject.wizard.form</field>
        <field name="model">estate.document.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rechazar documento">
                <group>
                    <field name="document_id" invisible="1"/>
                    <field name="reason" placeholder="Ej: copia ilegible, expirado, no firmado..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" string="Rechazar" type="object" class="btn-danger"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         DOCUMENTO — VISTA LIST
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_view_tree" model="ir.ui.view">
        <field name="name">estate.document.tree</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <list string="Documentos" default_order="date desc"
                  decoration-muted="state == 'pending'"
                  decoration-info="state == 'received'"
                  decoration-success="state == 'verified'"
                  decoration-danger="state == 'rejected'"
                  decoration-warning="confidentiality == 'confidential'">
                <field name="name"/>
                <field name="type_id"/>
                <field name="type_category" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'pending'"
                       decoration-info="state == 'received'"
                       decoration-success="state == 'verified'"
                       decoration-danger="state == 'rejected'"/>
                <field name="confidentiality" optional="show" widget="badge"
                       decoration-warning="confidentiality == 'restricted'"
                       decoration-danger="confidentiality == 'confidential'"/>
                <field name="property_id" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="contract_id" optional="show"/>
                <field name="lead_id" optional="hide"/>
                <field name="date"/>
                <field name="expiration_date" optional="hide"/>
                <field name="file_size" optional="hide"/>
                <field name="filename" optional="hide"/>
                <button name="action_verify" string="Verificar" type="object"
                        icon="fa-check" invisible="state != 'received'"
                        groups="estate_management.estate_group_manager"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         DOCUMENTO — VISTA KANBAN (agrupada por categoría)
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_view_kanban" model="ir.ui.view">
        <field name="name">estate.document.kanban</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <kanban default_group_by="type_category" class="o_kanban_small_column"
                    sample="1">
                <field name="state"/>
                <field name="confidentiality"/>
                <field name="type_id"/>
                <field name="filename"/>
                <field name="file_size"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="type_id"/>
                                    </small>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'pending': 'secondary', 'received': 'info', 'verified': 'success', 'rejected': 'danger', 'archived': 'muted'}}"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="property_id" t-if="record.property_id.raw_value"/>
                                <field name="partner_id" t-if="record.partner_id.raw_value"/>
                                <field name="contract_id" t-if="record.contract_id.raw_value"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="date"/>
                                    <span t-if="record.confidentiality.raw_value == 'restricted'"
                                          class="badge text-bg-warning ms-1">Restringido</span>
                                    <span t-if="record.confidentiality.raw_value == 'confidential'"
                                          class="badge text-bg-danger ms-1">Confidencial</span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span t-if="record.file_size.raw_value > 0">
                                        <field name="file_size"/> MB
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         DOCUMENTO — VISTA FORM (statusbar + acciones del ciclo)
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_view_form" model="ir.ui.view">
        <field name="name">estate.document.form</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <form string="Documento">
                <header>
                    <button name="action_verify" string="Verificar"
                            type="object" class="btn-success" icon="fa-check"
                            invisible="state != 'received'"
                            groups="estate_management.estate_group_manager"/>
                    <button name="action_reject" string="Rechazar"
                            type="object" class="btn-danger" icon="fa-times"
                            invisible="state not in ['received', 'verified']"
                            groups="estate_management.estate_group_manager"/>
                    <button name="action_archive_doc" string="Archivar"
                            type="object" icon="fa-archive"
                            invisible="state != 'verified'"/>
                    <button name="action_reset_to_pending" string="Volver a Pendiente"
                            type="object" icon="fa-undo"
                            invisible="state == 'pending'"
                            groups="estate_management.estate_group_manager"/>
                    <button name="action_ocr_extract" string="Extraer con IA"
                            type="object" icon="fa-magic" class="btn-info"
                            invisible="not file"
                            title="Analiza el archivo con Gemini Vision y extrae los datos automáticamente"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,received,verified,archived"/>
                </header>
                <sheet>
                    <!-- Banner cuando rechazado -->
                    <div class="alert alert-danger mb-2" role="alert" invisible="state != 'rejected'">
                        <i class="fa fa-exclamation-triangle me-1" title="Rechazado"/>
                        <strong>Documento rechazado:</strong> <field name="rejection_reason" readonly="1" nolabel="1"/>
                    </div>

                    <!-- Banner cuando placeholder -->
                    <div class="alert alert-info mb-2" role="alert" invisible="state != 'pending' or file">
                        <i class="fa fa-clock-o me-1" title="Pendiente"/>
                        Este documento es un <b>placeholder pendiente</b>. Sube el archivo para que se marque como Recibido automáticamente.
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ej: Cédula del cliente Juan Pérez"/></h1>
                    </div>

                    <group>
                        <group string="Tipo y clasificación">
                            <field name="type_id" options="{'no_create_edit': True}"/>
                            <field name="type_category" readonly="1"/>
                            <field name="confidentiality"/>
                        </group>
                        <group string="Fechas y autoría">
                            <field name="date"/>
                            <field name="expiration_date"/>
                            <field name="uploaded_by" readonly="1"/>
                            <field name="verified_by" readonly="1" invisible="not verified_by"/>
                            <field name="verified_date" readonly="1" invisible="not verified_date"/>
                        </group>
                    </group>

                    <group string="Vinculación">
                        <group>
                            <field name="property_id"/>
                            <field name="contract_id"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                        </group>
                    </group>

                    <group string="Archivo">
                        <field name="file" filename="filename" widget="binary"/>
                        <field name="filename" invisible="1"/>
                        <field name="file_size" readonly="1"/>
                    </group>

                    <group string="Notas" invisible="not notes and state != 'pending'">
                        <field name="notes" nolabel="1"/>
                    </group>

                    <group string="Datos extraídos por IA (OCR)" invisible="not ocr_result">
                        <field name="ocr_result" nolabel="1" readonly="1"
                               widget="text"
                               style="font-family: monospace; font-size: 12px; background: #f8f9fa; padding: 8px; border-radius: 4px;"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         DOCUMENTO — VISTA SEARCH
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_view_search" model="ir.ui.view">
        <field name="name">estate.document.search</field>
        <field name="model">estate.document</field>
        <field name="arch" type="xml">
            <search string="Buscar Documento">
                <field name="name"/>
                <field name="type_id"/>
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="contract_id"/>
                <separator/>
                <filter name="filter_pending"  string="Pendientes"   domain="[('state', '=', 'pending')]"/>
                <filter name="filter_received" string="Recibidos"    domain="[('state', '=', 'received')]"/>
                <filter name="filter_verified" string="Verificados"  domain="[('state', '=', 'verified')]"/>
                <filter name="filter_rejected" string="Rechazados"   domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter name="filter_contract" string="Contratos"    domain="[('type_category', '=', 'contract')]"/>
                <filter name="filter_identity" string="Identidad"    domain="[('type_category', '=', 'identity')]"/>
                <filter name="filter_property_cat" string="Propiedad" domain="[('type_category', '=', 'property')]"/>
                <filter name="filter_financial" string="Financieros" domain="[('type_category', '=', 'financial')]"/>
                <filter name="filter_legal"    string="Legales"     domain="[('type_category', '=', 'legal')]"/>
                <separator/>
                <filter name="filter_confidential" string="Confidencial" domain="[('confidentiality', 'in', ['restricted', 'confidential'])]"/>
                <filter name="filter_expiring" string="Expira en 30 días"
                        domain="[('expiration_date', '!=', False), ('expiration_date', '&lt;=', (context_today() + relativedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_category"  string="Categoría" context="{'group_by': 'type_category'}"/>
                    <filter name="group_state"     string="Estado"    context="{'group_by': 'state'}"/>
                    <filter name="group_property"  string="Propiedad" context="{'group_by': 'property_id'}"/>
                    <filter name="group_partner"   string="Cliente"   context="{'group_by': 'partner_id'}"/>
                    <filter name="group_contract"  string="Contrato"  context="{'group_by': 'contract_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         ACCIÓN PRINCIPAL
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_document_action" model="ir.actions.act_window">
        <field name="name">Documentos</field>
        <field name="res_model">estate.document</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Subir un nuevo documento</p>
            <p>Los documentos pueden vincularse a propiedades, clientes, leads o contratos.</p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         INTEGRACIÓN: pestaña en CRM Lead
    ═══════════════════════════════════════════════════════════ -->
    <record id="crm_lead_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.docs</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Documentos" name="estate_docs">
                    <field name="document_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="type_id"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'received'"
                                   decoration-success="state == 'verified'"
                                   decoration-danger="state == 'rejected'"/>
                            <field name="confidentiality" widget="badge"/>
                            <field name="date"/>
                            <field name="file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         INTEGRACIÓN: smart-buttons
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_property_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">estate.property.form.inherit.docs</field>
        <field name="model">estate.property</field>
        <field name="inherit_id" ref="estate_management.estate_property_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object"
                        class="oe_stat_button" icon="fa-folder-open">
                    <field name="document_count" widget="statinfo" string="Documentos"/>
                </button>
            </xpath>
        </field>
    </record>

    <record id="res_partner_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.docs</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object"
                        class="oe_stat_button" icon="fa-file-text-o">
                    <field name="document_count" widget="statinfo" string="Documentos"/>
                </button>
                <button name="action_view_full_folder" type="object"
                        class="oe_stat_button" icon="fa-folder-open">
                    <span>Carpeta completa</span>
                </button>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         INTEGRACIÓN: smart-button en Contrato + pestaña O2M
    ═══════════════════════════════════════════════════════════ -->
    <record id="estate_contract_view_form_inherit_docs" model="ir.ui.view">
        <field name="name">estate.contract.form.inherit.docs</field>
        <field name="model">estate.contract</field>
        <field name="inherit_id" ref="estate_management.estate_contract_view_form"/>
        <field name="arch" type="xml">
            <!-- Smart-button Documentos -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object"
                        class="oe_stat_button" icon="fa-folder-open">
                    <field name="document_count" string="Documentos" widget="statinfo"/>
                </button>
            </xpath>
            <!-- Pestaña de documentos del contrato (antes de la pestaña heredada) -->
            <xpath expr="//page[@name='legacy_documents']" position="before">
                <page string="Documentos del Contrato" name="contract_docs_linked">
                    <field name="document_ids">
                        <list editable="bottom"
                              decoration-muted="state == 'pending'"
                              decoration-info="state == 'received'"
                              decoration-success="state == 'verified'"
                              decoration-danger="state == 'rejected'">
                            <field name="name"/>
                            <field name="type_id"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'received'"
                                   decoration-success="state == 'verified'"
                                   decoration-danger="state == 'rejected'"/>
                            <field name="confidentiality" widget="badge"/>
                            <field name="date"/>
                            <field name="file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
