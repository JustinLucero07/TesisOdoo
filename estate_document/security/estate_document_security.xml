<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══════════════════════════════════════════════════════
             REGLAS DE CONFIDENCIALIDAD
             - public:       todos ven
             - internal:     cualquier asesor del sistema
             - restricted:   solo creador o usuario asignado a la entidad relacionada + manager
             - confidential: solo manager/admin
        ═══════════════════════════════════════════════════════════ -->

        <!-- Agente: ve los suyos + los internal/public que estén ligados a sus entidades.
             NO ve restricted de otros agentes ni nada confidential. -->
        <record id="rule_document_agent" model="ir.rule">
            <field name="name">Documento: agente — visibilidad por confidencialidad</field>
            <field name="model_id" ref="model_estate_document"/>
            <field name="domain_force">[
                '|',
                    ('confidentiality', 'in', ['public', 'internal']),
                    '&amp;',
                        ('confidentiality', '=', 'restricted'),
                        '|', '|', '|',
                            ('create_uid', '=', user.id),
                            ('property_id.user_id', '=', user.id),
                            ('lead_id.user_id', '=', user.id),
                            ('contract_id.user_id', '=', user.id),
            ]</field>
            <field name="groups" eval="[(4, ref('estate_management.estate_group_agent'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: ve todos -->
        <record id="rule_document_manager" model="ir.rule">
            <field name="name">Documento: manager/admin ven todos</field>
            <field name="model_id" ref="model_estate_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('estate_management.estate_group_manager'))]"/>
        </record>

        <!-- Admin: full access (incluye unlink) -->
        <record id="rule_document_admin" model="ir.rule">
            <field name="name">Documento: admin ve todos sin restricción</field>
            <field name="model_id" ref="model_estate_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('estate_management.estate_group_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
