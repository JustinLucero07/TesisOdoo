<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- El menú de facturación se ha consolidado en estate_menus.xml -->


    <!-- Heredar la vista de facturas para inyectar propiedad y botón de estado -->
    <record id="view_move_form_inherit_estate" model="ir.ui.view">
        <field name="name">account.move.form.inherit.estate</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="property_id"/>
                <field name="estate_transaction_type"/>
                <field name="closing_payment_type"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_mark_property_from_invoice"
                        string="Marcar Propiedad como Vendida/Arrendada"
                        type="object" class="btn-success" icon="fa-check-circle"
                        invisible="property_id == False or payment_state not in ('paid','in_payment') or move_type != 'out_invoice'"/>
            </xpath>
        </field>
    </record>

    <!-- Mostrar QR de propiedad en el formulario de factura -->
    <record id="view_move_form_inherit_estate_qr" model="ir.ui.view">
        <field name="name">account.move.form.inherit.estate.qr</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='narration']" position="before">
                <div class="row" invisible="property_id == False or move_type != 'out_invoice'">
                    <div class="col-md-9">
                        <group string="Datos de la Propiedad">
                            <field name="property_id" readonly="1"/>
                            <field name="estate_transaction_type" readonly="1"/>
                        </group>
                    </div>
                    <div class="col-md-3 text-center">
                        <div class="small text-muted mb-1">QR Propiedad</div>
                        <field name="property_qr_image" widget="image"
                               style="max-height:100px; max-width:100px;" readonly="1" nolabel="1"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Heredar la vista de lista de facturas para inyectar propiedad -->
    <record id="view_invoice_tree_inherit_estate" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.estate</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_partner_display_name']" position="after">
                <field name="property_id" optional="show"/>
                <field name="estate_transaction_type" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
