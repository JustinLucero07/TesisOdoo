<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_estate_property" model="ir.sequence">
            <field name="name">Secuencia Propiedad</field>
            <field name="code">estate.property</field>
            <field name="prefix">PROP-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_estate_commission" model="ir.sequence">
            <field name="name">Secuencia Comisión</field>
            <field name="code">estate.commission</field>
            <field name="prefix">COM-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_estate_offer" model="ir.sequence">
            <field name="name">Secuencia Oferta</field>
            <field name="code">estate.property.offer</field>
            <field name="prefix">OFR-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_estate_tenant_request" model="ir.sequence">
            <field name="name">Secuencia Solicitud Inquilino</field>
            <field name="code">estate.tenant.request</field>
            <field name="prefix">MANT-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_estate_appraisal" model="ir.sequence">
            <field name="name">Secuencia Tasación</field>
            <field name="code">estate.appraisal</field>
            <field name="prefix">TAS-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
