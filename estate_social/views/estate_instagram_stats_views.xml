<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         VISTA FORMULARIO — Estadísticas de una publicación
    ════════════════════════════════════════════════════════ -->
    <record id="estate_instagram_stats_view_form" model="ir.ui.view">
        <field name="name">estate.instagram.stats.form</field>
        <field name="model">estate.instagram.stats</field>
        <field name="arch" type="xml">
            <form string="Estadísticas de Instagram">
                <header>
                    <button name="action_refresh" string="Actualizar desde Instagram"
                            type="object" class="oe_highlight" icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="property_id" readonly="1"/>
                        </h1>
                        <div class="text-muted small">
                            Post ID: <field name="ig_post_id" readonly="1" class="text-monospace"/>
                            &amp;nbsp;·&amp;nbsp;
                            Actualizado: <field name="stats_date" readonly="1" widget="datetime"/>
                        </div>
                    </div>

                    <!-- Alerta de error -->
                    <div class="alert alert-warning" role="alert"
                         invisible="not fetch_error">
                        <i class="fa fa-exclamation-triangle"/> <field name="fetch_error" readonly="1"/>
                        <div class="mt-1 small text-muted">
                            Nota: Instagram solo entrega métricas de posts publicados hace más de 24 horas
                            y de cuentas Business/Creator con el token correcto.
                        </div>
                    </div>

                    <!-- KPI Cards -->
                    <div class="row mt-3 mb-3">
                        <div class="col-6 col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-center p-3 h-100" style="border-left: 4px solid #004274 !important;">
                                <div class="display-6 fw-bold text-primary">
                                    <field name="impressions" readonly="1"/>
                                </div>
                                <div class="text-muted small mt-1">Impresiones</div>
                                <div class="text-muted" style="font-size:10px">Veces que fue visto</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-center p-3 h-100" style="border-left: 4px solid #00897B !important;">
                                <div class="display-6 fw-bold" style="color:#00897B">
                                    <field name="reach" readonly="1"/>
                                </div>
                                <div class="text-muted small mt-1">Alcance</div>
                                <div class="text-muted" style="font-size:10px">Cuentas únicas</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-center p-3 h-100" style="border-left: 4px solid #E53935 !important;">
                                <div class="display-6 fw-bold text-danger">
                                    <field name="total_interactions" readonly="1"/>
                                </div>
                                <div class="text-muted small mt-1">Interacciones</div>
                                <div class="text-muted" style="font-size:10px">Likes + comentarios + más</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 mb-3">
                            <div class="card border-0 shadow-sm text-center p-3 h-100" style="border-left: 4px solid #FF9800 !important;">
                                <div class="display-6 fw-bold" style="color:#FF9800">
                                    <field name="engagement_rate" readonly="1" widget="float" digits="[5,2]"/>
                                    <span class="fs-4">%</span>
                                </div>
                                <div class="text-muted small mt-1">Engagement</div>
                                <div class="text-muted" style="font-size:10px">Interacciones / Alcance</div>
                            </div>
                        </div>
                    </div>

                    <!-- Detalle de métricas -->
                    <group string="Detalle de Métricas">
                        <group>
                            <field name="likes" readonly="1"/>
                            <field name="comments" readonly="1"/>
                            <field name="shares" readonly="1"/>
                            <field name="saves" readonly="1"/>
                        </group>
                        <group>
                            <field name="impressions" readonly="1"/>
                            <field name="reach" readonly="1"/>
                            <field name="reach_rate" readonly="1" widget="float" digits="[5,2]"
                                   string="Tasa de Alcance (%)"/>
                            <field name="engagement_rate" readonly="1" widget="float" digits="[5,2]"
                                   string="Tasa de Engagement (%)"/>
                        </group>
                    </group>

                    <!-- Referencia de calidad -->
                    <div class="alert alert-info mt-3" role="alert" style="font-size:0.85em">
                        <strong>Referencias de engagement en inmobiliarias:</strong>
                        &lt; 1% = Bajo &amp;nbsp;|&amp;nbsp;
                        1–3% = Promedio &amp;nbsp;|&amp;nbsp;
                        3–6% = Bueno &amp;nbsp;|&amp;nbsp;
                        &gt; 6% = Excelente
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         VISTA LISTA — Todas las publicaciones
    ════════════════════════════════════════════════════════ -->
    <record id="estate_instagram_stats_view_list" model="ir.ui.view">
        <field name="name">estate.instagram.stats.list</field>
        <field name="model">estate.instagram.stats</field>
        <field name="arch" type="xml">
            <list string="Estadísticas Instagram"
                  decoration-danger="engagement_rate &lt; 1 and impressions &gt; 0"
                  decoration-warning="engagement_rate &gt;= 1 and engagement_rate &lt; 3"
                  decoration-success="engagement_rate &gt;= 3">
                <field name="property_id"/>
                <field name="ig_post_id" optional="hide"/>
                <field name="stats_date" widget="datetime"/>
                <field name="impressions" optional="show"/>
                <field name="reach"/>
                <field name="likes"/>
                <field name="comments"/>
                <field name="shares" optional="show"/>
                <field name="saves" optional="show"/>
                <field name="total_interactions"/>
                <field name="engagement_rate" widget="float" digits="[5,2]" string="Engagement %"/>
                <field name="reach_rate" widget="float" digits="[5,2]" string="Alcance %" optional="show"/>
                <button name="action_refresh" string="Actualizar" type="object"
                        icon="fa-refresh" title="Actualizar estadísticas desde Instagram"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         VISTA PIVOT — Comparativa entre publicaciones
    ════════════════════════════════════════════════════════ -->
    <record id="estate_instagram_stats_view_pivot" model="ir.ui.view">
        <field name="name">estate.instagram.stats.pivot</field>
        <field name="model">estate.instagram.stats</field>
        <field name="arch" type="xml">
            <pivot string="Comparativa Instagram" display_quantity="true">
                <field name="property_id" type="row"/>
                <field name="impressions" type="measure"/>
                <field name="reach" type="measure"/>
                <field name="likes" type="measure"/>
                <field name="comments" type="measure"/>
                <field name="shares" type="measure"/>
                <field name="saves" type="measure"/>
                <field name="total_interactions" type="measure"/>
                <field name="engagement_rate" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         ACCIÓN — Lista global de estadísticas
    ════════════════════════════════════════════════════════ -->
    <record id="action_instagram_stats_all" model="ir.actions.act_window">
        <field name="name">Estadísticas Instagram</field>
        <field name="res_model">estate.instagram.stats</field>
        <field name="view_mode">list,pivot,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sin estadísticas aún
            </p>
            <p>
                Publica una propiedad en Instagram y luego haz clic en
                <strong>Ver Stats Instagram</strong> desde el formulario de la propiedad.
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         MENÚ — Bajo Redes Sociales o Informes
    ════════════════════════════════════════════════════════ -->
    <menuitem id="menu_instagram_stats"
              name="Stats Instagram"
              parent="estate_reports.estate_menu_reports_root"
              action="action_instagram_stats_all"
              sequence="25"
              groups="base.group_user"/>

    <!-- ═══════════════════════════════════════════════════
         BOTÓN en formulario de propiedad
    ════════════════════════════════════════════════════════ -->
    <record id="estate_property_ig_stats_button" model="ir.ui.view">
        <field name="name">estate.property.ig.stats.button</field>
        <field name="model">estate.property</field>
        <field name="inherit_id" ref="estate_social.estate_property_social_buttons"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='social']" position="inside">
                <group invisible="not ig_published">
                    <div class="text-center py-2">
                        <button name="action_view_instagram_stats"
                                string="Ver Estadísticas de Instagram"
                                type="object"
                                class="btn btn-outline-dark"
                                icon="fa-bar-chart"/>
                        <p class="text-muted small mt-2">
                            Las métricas están disponibles 24h después de la publicación.
                            Requiere Page Access Token en Ajustes.
                        </p>
                    </div>
                </group>
            </xpath>
        </field>
    </record>

    <!-- CRON: actualización diaria automática -->
    <record id="cron_refresh_instagram_stats" model="ir.cron">
        <field name="name">Actualizar Estadísticas Instagram (diario)</field>
        <field name="model_id" ref="estate_social.model_estate_instagram_stats"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_all_stats()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
